LLM_MODEL=deepseek/deepseek-v4-flash

# Fallback automático (opcional): usado quando a chamada ao LLM_MODEL falhar por erro
# de infraestrutura (timeout, 5xx, rate limit, autenticação) — não quando o modelo
# responde normalmente sem tool_calls (isso é um resultado vazio legítimo).
# Deixe indefinida para manter o comportamento atual (sem fallback).
# Candidato sugerido: GPT OSS 20B na Bedrock (openai.gpt-oss-20b). Alternativas do
# mesmo shortlist de custo/capacidade: GLM 4.7 Flash, Nemotron Nano 9B v2, MiniMax M2
# (Model ID de cada um a confirmar no console Bedrock antes de usar).
# LLM_MODEL_FALLBACK=bedrock/openai.gpt-oss-20b
# AWS_REGION_BEDROCK=us-east-1

# Em produção: FILMBOT_SECRET_ARN contém llm_api_key, tmdb_api_key e filmbot_password
# FILMBOT_SECRET_ARN=arn:aws:secretsmanager:...

# Em desenvolvimento local: usar LLM_API_KEY diretamente (fallback quando FILMBOT_SECRET_ARN não está definida)
LLM_API_KEY=sk-...

AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
ATHENA_S3_OUTPUT=s3://seu-bucket-temp/athena-results/
GLUE_DATABASE=seu_glue_database
SPEC_TABLE=sua_tabela_spec

# Transcrição de áudio (entrada alternativa por voz, opcional): Whisper via litellm.
# Em produção: transcription_api_key também deve estar no FILMBOT_SECRET_ARN (chave Groq).
# Indefinida = campo de transcrição fica indisponível (o texto continua funcionando normalmente).
TRANSCRIPTION_MODEL=groq/whisper-large-v3-turbo
TRANSCRIPTION_API_KEY=gsk_...
